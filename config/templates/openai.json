{
  "name": "openai",
  "displayName": "OpenAI",
  "description": "OpenAI API access for chat completions and embeddings",
  "baseUrl": "https://api.openai.com/v1",
  "secretRef": "openai_api_key",
  "secretEnvHint": "Your OpenAI API key (Platform → API keys)",
  "allowedActions": [
    "issue",
    "chat.completions.create",
    "embeddings.create"
  ],
  "allowedScopes": [
    "openai:chat:create",
    "openai:embeddings:create"
  ],
  "defaultScopes": [
    "openai:chat:create"
  ],
  "defaultAllowedAgents": [
    "*"
  ],
  "endpoints": {
    "chat.completions.create": {
      "method": "POST",
      "path": "/chat/completions",
      "requiredScope": [
        "openai:chat:create"
      ]
    },
    "embeddings.create": {
      "method": "POST",
      "path": "/embeddings",
      "requiredScope": [
        "openai:embeddings:create"
      ]
    }
  }
}
